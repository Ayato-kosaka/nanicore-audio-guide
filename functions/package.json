{
  "name": "functions",
  "scripts": {
    "dev": "concurrently \"pnpm:watch\" \"pnpm:emulate\"",
    "watch": "concurrently \"tsc --watch\" \"pnpm run copy:shared\"",
    "copy:shared": "nodemon --watch ../shared/prisma --exec \"rm -rf lib/shared/prisma && cp -r ../shared/prisma lib/shared/prisma\"",
    "emulate": "firebase emulators:start --only functions",
    "build": "tsc && rm -rf lib/shared/prisma && cp -r ../shared/prisma lib/shared/prisma",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "start": "pnpm dev",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .js,.ts"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/functions/src/index.js",
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/text-to-speech": "^6.0.1",
    "@google-cloud/vision": "^5.1.0",
    "@prisma/client": "^6.6.0",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.7",
    "express": "4.18.2",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.6.0",
    "typescript": "^4.9.0"
  },
  "private": true
}