generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["dev"]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model backend_event_logs {
  id                String                          @id
  event_name        String?
  error_level       backend_event_logs_error_level?
  function_name     String?
  user_id           String?
  payload           Json?                           @db.Json
  request_id        String?
  created_at        DateTime                        @default(now()) @db.Timestamptz(6)
  created_commit_id String

  @@index([created_at], map: "idx_backend_event_logs_created_at")
  @@index([error_level], map: "idx_backend_event_logs_error_level")
  @@index([request_id], map: "idx_backend_event_logs_request_id")
  @@schema("dev")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model external_api_logs {
  id                String   @id
  request_id        String?
  function_name     String?
  api_name          String?
  endpoint          String?
  request_payload   Json?    @db.Json
  response_payload  Json?    @db.Json
  status_code       Int?     @db.SmallInt
  error_message     String?
  response_time_ms  Int?
  user_id           String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  created_commit_id String

  @@index([created_at], map: "idx_external_api_logs_created_at")
  @@index([request_id], map: "idx_external_api_logs_request_id")
  @@index([status_code], map: "idx_external_api_logs_status_code")
  @@schema("dev")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model frontend_event_logs {
  id                  String                           @id
  user_id             String?
  event_name          String?
  error_level         frontend_event_logs_error_level? @default(debug)
  screen_name         String?
  payload             String?
  created_at          DateTime                         @default(now()) @db.Timestamptz(6)
  created_app_version String
  created_commit_id   String

  @@index([created_at], map: "idx_frontend_event_logs_created_at")
  @@index([error_level], map: "idx_frontend_event_logs_error_level")
  @@schema("dev")
}

enum backend_event_logs_error_level {
  trace
  debug
  info
  warn
  error

  @@schema("dev")
}

enum frontend_event_logs_error_level {
  trace
  debug
  info
  warn
  error

  @@schema("dev")
}
