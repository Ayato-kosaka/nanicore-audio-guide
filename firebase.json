{
	"functions": [
		{
			"source": "functions",
			"codebase": "default",
			"ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"]
		}
	],
	"hosting": {
		"public": "app-expo/dist",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
		"rewrites": [
			{
				"source": "**",
				"destination": "/index.html"
			}
		]
	},
	"storage": {
		"rules": "infra/firebase/storage.rules"
	},
	"emulators": {
		"functions": {
			"port": 5001
		},
		"ui": {
			"enabled": false
		},
		"singleProjectMode": true
	},
	"remoteconfig": {
		"template": "infra/firebase/remoteconfig.template.json"
	}
}
