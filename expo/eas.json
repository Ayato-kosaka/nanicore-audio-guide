{
  "cli": {
    "version": ">= 16.3.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "ascAppId": "${ASC_APP_ID}"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}