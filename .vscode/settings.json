{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always"
  },
  "eslint.validate": [
    "javascript",
    "typescript",
    "typescriptreact"
  ],
  "prettier.requireConfig": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "path-intellisense.mappings": {
    "@": "${workspaceRoot}/shared"
  }
}